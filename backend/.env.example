# 🩺 DiabetesAI - Environment Configuration
# Copy this file to .env and fill in your values

# MongoDB Configuration
# Atlas example:
MONGODB_URL=mongodb+srv://your_db_user:your_db_password@cluster0.example.mongodb.net/diabetes_db?retryWrites=true&w=majority&appName=Cluster0
# Local MongoDB alternative:
# MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=diabetes_db

# Security Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Optional bootstrap admin account
# Leave blank to disable automatic admin creation.
BOOTSTRAP_ADMIN_PHONE=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=System Administrator
BOOTSTRAP_ADMIN_AGE=30
BOOTSTRAP_ADMIN_GENDER=Nam

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:5500,http://127.0.0.1:3000,http://127.0.0.1:5000,http://127.0.0.1:5500,null

# Groq AI Configuration (optional - for AI-powered recommendations)
GROQ_API_KEY=your-groq-api-key-here

# Logging Configuration
LOG_LEVEL=INFO

