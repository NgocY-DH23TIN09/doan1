# ─── MongoDB ──────────────────────────────────────────────
# URL kết nối MongoDB (local hoặc MongoDB Atlas)
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=diabetes_db

# ─── Bảo mật JWT ──────────────────────────────────────────
# !! THAY ĐỔI GIÁ TRỊ NÀY trong production !!
# Tạo key ngẫu nhiên: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-this-in-production

# ─── Gemini AI (tùy chọn) ─────────────────────────────────
# Lấy tại: https://aistudio.google.com/app/apikey
# Bỏ trống nếu không dùng AI tư vấn
GEMINI_API_KEY=

# ─── CORS ─────────────────────────────────────────────────
# Danh sách origin được phép, phân cách bằng dấu phẩy
# Dùng * cho development, nhưng hãy giới hạn trong production
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5500
